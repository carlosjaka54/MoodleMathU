        </div>
    </div>
    
    {{{ output.standard_end_of_body_html }}}
    
    {{! Modal de Video para Página de Inicio }}
    <div id="videoModalInicio" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:999999;padding:20px;overflow:auto;">
        <div style="position:relative;background:white;max-width:1100px;margin:50px auto;border-radius:15px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.5);">
            <div style="background:linear-gradient(135deg,#7CB342 0%,#8BC34A 100%);padding:20px 25px;display:flex;justify-content:space-between;align-items:center;">
                <h3 style="margin:0;color:white;font-size:22px;font-family:Arial,sans-serif;">UniPutumayo</h3>
                <button id="btnCerrarModalVideo" style="background:rgba(255,255,255,0.2);border:none;color:white;width:45px;height:45px;border-radius:50%;font-size:28px;cursor:pointer;transition:all 0.3s ease;line-height:1;font-weight:bold;">×</button>
            </div>
            <div id="videoContainerInicio" style="position:relative;width:100%;padding-bottom:56.25%;height:0;background:#000;"></div>
            <div style="background:#f8f9fa;padding:18px 25px;text-align:center;border-top:1px solid #e0e0e0;">
                <p style="margin:0;color:#666;font-size:15px;font-family:Arial,sans-serif;">ℹ️ Este video contiene información importante para tu aprendizaje en la plataforma.</p>
            </div>
        </div>
    </div>
    
    {{#js}}
    require(['jquery'], function($) {
        // Función para cerrar el modal
        window.cerrarVideoModal = function() {
            var modal = document.getElementById('videoModalInicio');
            var contenedor = document.getElementById('videoContainerInicio');
            
            if (modal) {
                modal.style.display = 'none';
                contenedor.innerHTML = '';
                document.body.style.overflow = '';
                
                // Guardar que ya vio el video
                localStorage.setItem('video_modal_visto', new Date().toDateString());
                
                console.log('✅ Modal cerrado');
            }
        };
        
        // Event listener para el botón de cerrar
        var btnCerrar = document.getElementById('btnCerrarModalVideo');
        if (btnCerrar) {
            btnCerrar.addEventListener('click', window.cerrarVideoModal);
        }
        
        // Cerrar con clic fuera del modal
        var modalInicio = document.getElementById('videoModalInicio');
        if (modalInicio) {
            modalInicio.addEventListener('click', function(e) {
                if (e.target.id === 'videoModalInicio') {
                    window.cerrarVideoModal();
                }
            });
        }
        
        // Cerrar con tecla Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' || e.key === 'Esc') {
                var modal = document.getElementById('videoModalInicio');
                if (modal && modal.style.display === 'block') {
                    window.cerrarVideoModal();
                }
            }
        });
        
        // Solo ejecutar en la página de inicio (frontpage)
        var esPaginaInicio = $('body').hasClass('pagelayout-frontpage') || 
                            ($('body').hasClass('path-site') && window.location.pathname === '/') ||
                            (window.location.pathname.indexOf('/index.php') !== -1 && !window.location.search);
        
        if (esPaginaInicio) {
            console.log('📍 Estás en la página de inicio');
            
            // Verificar si ya vio el video hoy
            var hoy = new Date().toDateString();
            var visto = localStorage.getItem('video_modal_visto');
            
            if (visto !== hoy) {
                console.log('🎬 Preparando modal de video...');
                
                // Mostrar modal después de 2 segundos
                setTimeout(function() {
                    var modal = document.getElementById('videoModalInicio');
                    var contenedor = document.getElementById('videoContainerInicio');
                    
                    if (modal && contenedor) {
                        // Crear iframe
                        var iframe = document.createElement('iframe');
                        iframe.src = 'https://www.youtube.com/embed/nnQHxEnq6Go?autoplay=1&rel=0';
                        iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;';
                        iframe.setAttribute('allowfullscreen', '');
                        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
                        
                        contenedor.appendChild(iframe);
                        modal.style.display = 'block';
                        document.body.style.overflow = 'hidden';
                        
                        console.log('✅ Modal de video mostrado en página de inicio');
                    }
                }, 2000);
            } else {
                console.log('ℹ️ El usuario ya vio el video hoy');
            }
        } else {
            console.log('📍 No estás en la página de inicio - modal no se mostrará');
        }
        
        // Hacer que las imágenes de los cursos sean clickeables
        $(document).ready(function() {
            $('.coursebox').each(function() {
                var $coursebox = $(this);
                var $courseLink = $coursebox.find('.coursename a');
                
                if ($courseLink.length > 0) {
                    var courseUrl = $courseLink.attr('href');
                    
                    // Hacer que la imagen sea clickeable
                    $coursebox.find('.courseimage').on('click', function(e) {
                        e.preventDefault();
                        window.location.href = courseUrl;
                    });
                    
                    // También hacer que toda la tarjeta sea clickeable (excepto enlaces)
                    $coursebox.on('click', function(e) {
                        // Solo si no se hace clic en un enlace
                        if (!$(e.target).is('a') && !$(e.target).closest('a').length) {
                            window.location.href = courseUrl;
                        }
                    });
                    
                    // Agregar cursor pointer a toda la tarjeta
                    $coursebox.css('cursor', 'pointer');
                }
            });
            
            console.log('✅ Tarjetas de curso clickeables habilitadas');
        });
    });
    {{/js}}
</footer>

<!-- Footer Styles -->
<style>
/* Prevenir scroll horizontal */
body {
    overflow-x: hidden;
}

.custom-footer {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-top: 50px;
    overflow-x: hidden;
}

/* Main Footer Section */
.footer-main {
    background: linear-gradient(135deg, #7CB342 0%, #8BC34A 100%);
    padding: 50px 0 30px 0;
    color: #ffffff;
    width: 100%;
    box-sizing: border-box;
}

.footer-content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
    box-sizing: border-box;
}

.footer-col {
    padding: 0 25px;
}

/* Desktop column alignment */
.footer-col-first { text-align: left; }
.footer-col-second { text-align: left; }
.footer-col-third { text-align: left; }

/* Logo Section */
.footer-logo-section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.footer-logo-section img {
    width: 200px;
    max-width: 200px;
    height: auto;
    margin-bottom: 20px;
    display: block;
}

.footer-description {
    font-size: 18px;
    line-height: 1.8;
    color: #ffffff;
    margin: 0;
}

/* Footer Titles */
.footer-title {
    font-size: 26px;
    font-weight: bold;
    color: #ffffff;
    margin-bottom: 25px;
    margin-top: 0;
}

/* Social Links */
.social-links {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.social-link {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #ffffff;
    text-decoration: none;
    transition: transform 0.2s ease;
}

.social-link:hover {
    transform: translateX(5px);
    color: #ffffff;
}

.social-icon {
    width: 42px;
    height: 42px;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 20px;
}

.facebook-icon {
    color: #3b5998;
    display: inline-flex;
    align-items: center;
}

.facebook-icon svg {
    width: 16px;
    height: 16px;
}

.twitter-icon {
    color: #1DA1F2;
    font-size: 16px;
    display: inline-flex;
    align-items: center;
}

.twitter-icon svg {
    width: 16px;
    height: 16px;
}

.social-text {
    font-size: 20px;
    font-weight: 600;
}

/* Contact Section */
.contact-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.contact-institution {
    font-weight: bold;
    font-size: 18px;
    margin-bottom: 15px;
    color: #ffffff;
}

.contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    color: #ffffff;
    margin: 0;
}

.contact-icon {
    font-size: 16px;
}

.contact-email {
    color: #ffffff;
    text-decoration: underline;
}

.contact-email:hover {
    color: #f0f0f0;
}

/* Copyright Section */
.footer-copyright {
    background: #689F38;
    padding: 20px 0;
    width: 100%;
    box-sizing: border-box;
}

.copyright-text {
    text-align: center;
    color: #ffffff;
    margin: 0;
    font-size: 14px;
}

.copyright-link {
    color: #ffffff;
    text-decoration: underline;
}

.copyright-link:hover {
    color: #f0f0f0;
}

/* Moodle Essential Footer Elements */
.footer-moodle-content {
    display: none;
    /* Elementos ocultos visualmente pero presentes en el DOM para funcionalidad de Moodle */
}

.footer-moodle-content .container-fluid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.footer-support-link {
    margin: 5px 0;
    font-size: 14px;
}

.footer-support-link a {
    color: #007bff;
    text-decoration: none;
}

.footer-support-link a:hover {
    text-decoration: underline;
}

#course-footer {
    margin-bottom: 10px;
}

/* Responsive Design */
@media (max-width: 992px) {
    .footer-content-wrapper {
        max-width: 100%;
        padding: 0 15px;
    }
}

@media (max-width: 768px) {
    .custom-footer {
        margin-top: 30px;
    }
    
    .footer-main {
        padding: 30px 0 20px 0;
    }
    
    .footer-col {
        padding: 20px 15px;
        text-align: left;
        margin-bottom: 20px;
    }
    
    .footer-logo-section {
        align-items: flex-start;
    }
    
    .footer-logo-section img {
        width: 150px;
        max-width: 150px;
    }
    
    .footer-description {
        text-align: left;
        font-size: 13px;
    }
    
    .footer-title {
        font-size: 22px;
        margin-bottom: 20px;
    }
    
    .social-links {
        align-items: flex-start;
    }
    
    .contact-info {
        align-items: flex-start;
    }
    
    .contact-item {
        justify-content: flex-start;
        font-size: 14px;
    }
    
    .copyright-text {
        font-size: 12px;
        padding: 0 10px;
    }
    
    .footer-moodle-content {
        padding: 15px 0;
    }
    
    .footer-moodle-content .container-fluid {
        padding: 0 15px;
    }
}
</style>
